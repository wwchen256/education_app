---
layout: base.njk
---
<div class="chapter-header">
  {% if morphemes %}
  <div class="chapter-morphemes">
    {% for r in morphemes.roots %}
      <span class="morpheme morpheme--root">{{ r }}</span>
    {% endfor %}
    {% for p in morphemes.prefixes %}
      <span class="morpheme morpheme--prefix">{{ p }}</span>
    {% endfor %}
  </div>
  {% endif %}
  <p class="chapter-label">Chapter {{ chapternumber }}</p>
  <h1>{{ title }}</h1>
</div>

{{ content | safe }}

<nav class="chapter-nav">
  {% set prev = collections.chapters | getPrevChapter(page.url) %}
  {% set next = collections.chapters | getNextChapter(page.url) %}

  {% if prev %}
    <a class="chapter-nav__prev" href="{{ prev.url | url }}">← {{ prev.data.title }}</a>
  {% else %}
    <span></span>
  {% endif %}

  {% if next %}
    <a class="chapter-nav__next" href="{{ next.url | url }}">{{ next.data.title }} →</a>
  {% endif %}
</nav>
