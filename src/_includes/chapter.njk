---
layout: base.njk
---
<div class="chapter-header">
  {% if morphemes %}
  <div class="chapter-morphemes">
    {% for r in morphemes.roots %}
      <span class="morpheme morpheme--root">{{ r }}</span>
    {% endfor %}
    {% for p in morphemes.prefixes %}
      <span class="morpheme morpheme--prefix">{{ p }}</span>
    {% endfor %}
  </div>
  {% endif %}
  <p class="chapter-label">Chapter {{ chapternumber }}</p>
  <h1>{{ title }}</h1>
</div>

{{ content | safe }}

<nav class="chapter-nav">
  {% set chapters = collections.chapters %}
  {% set ns = namespace(idx=0) %}
  {% for ch in chapters %}
    {% if ch.url == page.url %}{% set ns.idx = loop.index0 %}{% endif %}
  {% endfor %}

  {% if ns.idx > 0 %}
    {% set prev = chapters[ns.idx - 1] %}
    <a class="chapter-nav__prev" href="{{ prev.url }}">← {{ prev.data.title }}</a>
  {% else %}
    <span></span>
  {% endif %}

  {% if ns.idx < chapters.length - 1 %}
    {% set next = chapters[ns.idx + 1] %}
    <a class="chapter-nav__next" href="{{ next.url }}">{{ next.data.title }} →</a>
  {% endif %}
</nav>
